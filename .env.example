# Port for local server (optional for later)
PORT=3000

# Gemini API Key (needed for live news summarization)
# Note: The SDK also checks GOOGLE_API_KEY if this is not set
GEMINI_API_KEY=your_gemini_api_key_here

# NewsAPI Key (get one free at https://newsapi.org/)
NEWS_API_KEY=your_news_api_key_here

# Firebase Realtime Database URL
# Example: https://your-project-id-default-rtdb.firebaseio.com/
FIREBASE_DATABASE_URL=your_firebase_database_url_here

# Path to Firebase Admin service account JSON credentials
# Example: ./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Web Push VAPID Configuration (M3: Real-Time Alerts)
# Leave blank to auto-generate and save to .env on boot
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your_email@example.com

# Alert Polling Interval (in minutes, default: 15)
POLL_INTERVAL_MINUTES=15

# Maximum Alerts allowed to be pushed per day (default: 5)
ALERT_MAX_PER_DAY=5

